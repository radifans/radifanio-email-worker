# Copy this file to .dev.vars for local development with `wrangler dev`.
# .dev.vars is Wrangler's equivalent of .env — it is gitignored.
#
# Cloudflare bindings (R2, D1, Queue) are declared in wrangler.toml and do not
# need to be listed here. Only plain-text secrets are set via this file locally
# and via `wrangler secret put <KEY>` in production.

# Required: API key for the REST API (X-API-Key header)
API_KEY=your-api-key-here

# Optional: Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=
